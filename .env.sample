# 取得方法は README.md の「外部サービスの設定」を参照

GITHUB_PERSONAL_ACCESS_TOKEN=
FIGMA_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
USER_GOOGLE_EMAIL=
MEET_RECORDING_FOLDER_ID=

# --- デフォルト出力先設定（省略可） ---
# Figma: 新規ファイル作成時の配置先（planKey）
# 空欄 = Drafts に作成
# 値の取得: mcp__figma__whoami で確認、または generate_figma_design を planKey なしで呼び出し返却されるプラン一覧から選択
FIGMA_DEFAULT_PLAN_KEY=

# Google Drive: 成果物の出力先フォルダ ID
# 空欄 = マイドライブ直下
# フォルダ URL 末尾がフォルダ ID（例: drive.google.com/drive/folders/{FOLDER_ID}）
GDRIVE_DEFAULT_OUTPUT_FOLDER_ID=
