{
  "allow": [
    "Bash(gh auth status 2>&1)",
    "Bash(gh issue:*)",
    "Bash(gh pr:*)",
    "Bash(gh label:*)",
    "Bash(gh project:*)",
    "Bash(gh run:*)",
    "Bash(gh search:*)",
    "Bash(gh api:*)",
    "Bash(git status:*)",
    "Bash(git diff:*)",
    "Bash(git branch:*)",
    "Bash(git log:*)",
    "Bash(git rev-parse:*)",
    "Bash(git fetch:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git checkout:*)",
    "Bash(git worktree:*)",
    "Bash(git stash:*)",
    "Bash(chmod +x:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(mkdir:*)",
    "mcp__claude_ai_Google_Calendar__gcal_list_events",
    "WebFetch(domain:docs.anthropic.com)"
  ],
  "deny": [
    "Bash(git push --force:*)",
    "Bash(git push -f:*)",
    "Bash(git reset --hard:*)",
    "Bash(git clean -f:*)",
    "Bash(git branch -D:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(sudo:*)",
    "Bash(rm -rf:*)",
    "Bash(gh pr merge:*)",
    "Bash(gh pr close:*)",
    "Bash(gh issue close:*)",
    "Bash(gh issue delete:*)",
    "Bash(gh repo delete:*)",
    "Bash(git branch -d main:*)",
    "Bash(git branch -D main:*)",
    "Bash(git push origin --delete main:*)",
    "Bash(git push origin :main:*)",
    "Bash(bash -c:*)",
    "Bash(sh -c:*)",
    "Bash(eval:*)"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-secrets.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-main-commit.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/warn-pr-without-review.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/warn-knowledge-change.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-rules-change.sh"
          }
        ]
      }
    ]
  }
}
