{
  "mcpServers": {
    "google-workspace": {
      "command": "sh",
      "args": [
        "-c",
        "set -a && . ./.env && set +a && uvx workspace-mcp --single-user --tool-tier complete"
      ],
      "env": {
        "MCP_SINGLE_USER_MODE": "true",
        "OAUTHLIB_INSECURE_TRANSPORT": "1"
      }
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    }
  }
}
